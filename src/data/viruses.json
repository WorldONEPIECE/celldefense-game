    "weaknesses": [
      { "card": "lysosome_fusion",    "multiplier": 2.0, "reason": "内体融合阶段直接降解" },
      { "card": "nuclear_pore_block", "multiplier": 1.8, "reason": "vRNP完全依赖核孔入核" },
      { "card": "ifitm_fortify",      "multiplier": 1.6, "reason": "IFITM3阻断膜融合步骤" }
